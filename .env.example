# Copie para .env local (não versionar).
# Na Vercel, configure as mesmas chaves em Project Settings → Environment Variables
# com escopos separados: Production (main) e Preview (homol + demais branches).

# --- Frontend / site estático (seguras para o browser; RLS no Supabase) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Opcional — defaults derivados da SUPABASE_URL se omitidos
SWIFT_API_URL=https://YOUR_PROJECT.supabase.co/functions/v1/swift-api
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# --- Somente Supabase Edge Functions / backend (NUNCA no frontend nem na Vercel pública) ---
# Configure no Supabase Dashboard → Edge Functions → Secrets
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
